rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      // Prevent users from updating sensitive fields like role, planTier, credits
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'planTier', 'credits', 'subscriptionStatus']);
      
      match /private/{document=**} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /projects/{projectId} {
      allow read: if resource.data.userId == request.auth.uid;
      allow create: if request.auth.uid != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if resource.data.userId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if resource.data.isPublic == true || resource.data.userId == request.auth.uid;
      allow create: if request.auth.uid != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if resource.data.userId == request.auth.uid;
    }

    match /rateLimiting/{ipAddress} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
